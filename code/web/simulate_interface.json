{
  "system_name": "Liver Metabolism Simulation",
  "version": "1.0",
  "metadata": {
    "time_unit": "minute",
    "rate_convention": "Negative = Consumption, Positive = Production"
  },
  "hierarchy": {
    "orchestrateSystemSignals": {
      "label": "全局激素与神经信号调控",
      "children": [
        "hormoneSignalTransduction",
        "neuralSignalIntegration",
        "immuneSignalInteraction",
        "signalDegradationModule"
      ]
    },
    "signalDegradationModule": {
      "label": "激素降解模块",
      "children": [
        "degradeInsulin",
        "degradeGlucagon",
        "inactivateCatecholamines"
      ]
    },
    "orchestrateGlucoseMetabolism": {
      "label": "糖代谢编排",
      "children": [
        "orchestrateGlycolysis",
        "orchestrateGluconeogenesis",
        "orchestrateGlycogen"
      ]
    },
    "orchestrateGlycolysis": {
      "label": "糖酵解途径",
      "children": [
        "hexokinase_step",
        "pfk1_step",
        "pyruvate_kinase_step",
        "pyruvate_destination_logic"
      ]
    },
    "orchestrateGluconeogenesis": {
      "label": "糖异生途径",
      "children": ["orchestrateGluconeogenesis-step"]
    },
    "orchestrateGlycogen": {
      "label": "糖原代谢模块",
      "children": [
        "orchestrateGlycogenSynthesis",
        "orchestrateGlycogenBreakdown"
      ]
    },
    "orchestrateLipidMetabolism": {
      "label": "脂质代谢编排",
      "children": [
        "fattyAcidSynthesis",
        "deNovoLipogenesis",
        "lipidTransport",
        "adiposeLipolysis",
        "betaOxidation"
      ]
    },
    "orchestrateAminoAcidMetabolism": {
      "label": "氨基酸代谢编排",
      "children": [
        "protein_metabolism",
        "aa_catabolism_step",
        "metabolite_export"
      ]
    },
    "orchestrateEnergyHomeostasis": {
      "label": "能量稳态编排",
      "children": [
        "tca_cycle",
        "oxidativePhosphorylation",
        "oxygen_supply",
        "ketogenesis"
      ]
    },
    "orchestrateNADHomeostasis": {
      "label": "NAD(H)/NADP(H) 稳态编排",
      "children": [
        "lactateFermentation",
        "nampt_Salvage",
        "deNovoNADSynthesis"
      ]
    },
    "orchestrateUreaCycle": {
      "label": "尿素循环整体编排",
      "children": [
        "urea_cycle"
      ]
    },
    "orchestrateDetoxification": {
      "label": "解毒与药物代谢编排",
      "children": [
        "phaseI_OxRed",
        "phaseII_Conjugation",
        "ethanol_ADH",
        "acetaldehyde_ALDH",
        "acetate_to_acetylcoa",
        "bilirubinUGT"
      ]
    },
    "orchestrateSynthesisSecretion": {
      "label": "合成与分泌编排",
      "children": [
        "bileAcidSynthesis",
        "bileExcretion",
        "plasmaProteinSynthesis",
        "coagulationFactorSynthesis"
      ]
    },
    "g6pase_G6P_to_Glucose": {
      "label": "葡萄糖-6-磷酸酶步 (G6P → Glucose)",
      "children": []
    },
    "cytosolicATPase_load": {
      "label": "胞质 ATPase 负荷",
      "children": []
    }
  },
  "reactions": {
    "hexokinase_step": {
      "id": "rate-hexokinase",
      "parent_module": "orchestrateGlycolysis",
      "display_name": "己糖激酶/葡萄糖激酶步",
      "rate_key": "hexokinase",
      "flux": {
        "glucose": -1.0,
        "atp": -1.0,
        "g6p": 1.0,
        "adp": 1.0
      },
      "regulation": "受血糖和胰岛素共同驱动，限制单步抽取葡萄糖和 ATP"
    },
    "pfk1_step": {
