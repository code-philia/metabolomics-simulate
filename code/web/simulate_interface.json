      "display_name": "磷酸果糖激酶-1 步",
      "rate_key": "pfk1",
      "flux": {
        "g6p": -1.0,
        "atp": -1.0,
        "f16bp": 1.0,
        "adp": 1.0
      },
      "regulation": "受 ATP、F16BP 反馈抑制，能量充足时减速"
    },
